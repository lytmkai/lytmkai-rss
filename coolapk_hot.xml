                &lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/1b908ad448c5a8df24af4172fadc7882.jpg&quot; &gt;
                &lt;p class=&quot;image-caption&quot; style=&quot;text-align: center;&quot;&gt;&lt;/p&gt;&lt;/div&gt;&lt;div class=&quot;img-container&quot; style=&quot;text-align: center;&quot;&gt;
                &lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/eb9c4d45a247db0271f08a9d6a9ecac9.jpg&quot; &gt;
                &lt;p class=&quot;image-caption&quot; style=&quot;text-align: center;&quot;&gt;&lt;/p&gt;&lt;/div&gt;&lt;div class=&quot;img-container&quot; style=&quot;text-align: center;&quot;&gt;
                &lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/d40f30f918743b8943d527bf34dd7143.jpg&quot; &gt;
