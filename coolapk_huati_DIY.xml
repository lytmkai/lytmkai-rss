a0544a4724f0a3cf2624edd46c.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/31c41472f37b1345d642fbe81c3c99c6.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/2c4964af73a7c2bc2683da3bdac8e0df.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/8f5118b44d19be9e15b93a42e5ea292c.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/64a3dab0ef8399b979ef0702ce6cbb0a.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/1dcedfa3195cdf813a5d80fe38263805.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/187f319ab95f77f4ad2cf82dbbafbd19.jpg&quot; &gt;</description><link>https://www.coolapk.com/feed/71284294</link><guid isPermaLink="false">https://www.coolapk.com/feed/71284294</guid><pubDate>Sat, 18 Apr 2026 08:23:52 GMT</pubDate><author>洪荒大腰子</author></item><item><title>想听 CD 了给电脑装光驱，以为自己老有操作呢给机箱钻了一堆孔，钻断一根钻头磨坏一根钻头，最后想起来有个东西叫扎带 ...... #DIY#</title><description>&lt;p&gt;想听 CD 了给电脑装光驱，以为自己老有操作呢给机箱钻了一堆孔，钻断一根钻头磨坏一根钻头，最后想起来有个东西叫扎带 ......
&lt;a class=&quot;feed-link-tag&quot; href=&quot;https://www.coolapk.com/t/DIY?type=0&quot;&gt;#DIY#&lt;/a&gt;&lt;/p&gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/3b3ebc5c83098080183d169ef423889f.jpg&quot; &gt;</description><link>https://www.coolapk.com/feed/71276495</link><guid isPermaLink="false">https://www.coolapk.com/feed/71276495</guid><pubDate>Fri, 17 Apr 2026 16:39:21 GMT</pubDate><author>Minecraft雪峰君</author></item><item><title>手搓的真蓝牙机[cos滑稽]#DIY# ，以后听歌不用过耳朵了，后续把颜色都换成蓝色的[酷][酷]#耳机#</title><description>&lt;p&gt;手搓的真蓝牙机[cos滑稽]&lt;a class=&quot;feed-link-tag&quot; href=&quot;https://www.coolapk.com/t/DIY?type=0&quot;&gt;#DIY#&lt;/a&gt; ，以后听歌不用过耳朵了，后续把颜色都换成蓝色的[酷][酷]&lt;a class=&quot;feed-link-tag&quot; href=&quot;https://www.coolapk.com/t/%E8%80%B3%E6%9C%BA?type=0&quot;&gt;#耳机#&lt;/a&gt;&lt;/p&gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/9f060b4ac9be5db1daf0f9471f4b8acc.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/4978524114e22b5d9e8c7c228a6cb482.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/5a7b726bb5dce91a65d897b8fe0b24b6.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/7184b16924edebffce2a72c117a6953f.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/fb919dd4f7974747ef8154bb65f0b652.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/e3da7804888082056c217f7e01871698.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/7396f44733057f71e8ae76055c4350ac.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/3e06bcef70dbbb216eb2eb5df44a554d.jpg&quot; &gt;&lt;img src=&quot;http://10.0.0.1:50108/coolapk_img/bed3d9c41814b72aa9428872cde0f191.jpg&quot; &gt;</description><link>https://www.coolapk.com/feed/71273304</link><guid isPermaLink="false">https://www.coolapk.com/feed/71273304</guid><pubDate>Fri, 17 Apr 2026 13:20:25 GMT</pubDate><author>珍特玛</author></item></channel></rss>